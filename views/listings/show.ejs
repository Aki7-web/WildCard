<% layout("/layouts/boilerplate") %>

    <div class="row">
        <div class="col-10 offset-3 mt-3">
    <h3><b><%= listing.title %></b></h3>
</div>

    <div class="card col-6 offset-3 mt-1 listing-card" >
    <img src="<%= listing.image.url%>" class="card-img-top show-img" alt="listing_image">
    <div class="card-body">
        <p class="card-text">Owned by <i><%= listing.owner.username %></i></p>
         <p class="card-text"> <%= listing.description %></p>
          <p class="card-text">&#8377;<%= listing.price.toLocaleString("en-IN") %> / night</p>
           <p class="card-text"> <%= listing.location %></p>
            <p class="card-text"><%= listing.country %></p>
            
      
    </div>
    </div>
   
    </form>

    </div>
   <% if(currUser && listing.owner._id.equals(currUser._id)){ %>
     <div class="btns mb-5">
        <a href="/listings/<%=listing._id%>/edit" class="btn btn-dark offset-3 col-1 edit-btn">Edit</a>
    <form method="post" action="/listings/<%=listing._id%>?_method=DELETE">
        <button class="btn btn-dark offset-5 ">Delete</button></form>
    </div>
      <% } %>

    <div class="col-8 offset-3 mb-5">
        <hr>
        <% if(currUser){ %>
        <h4>Leave a Review</h4>
        <form action="/listings/<%=listing._id%>/reviews" method="POST" novalidate class="needs-validation">
            <div>
                <label for="rating" class="form-label">Rating</label>
                <input type="range" name="review[rating]" id="rating" min="1" max="5" class="form-range">
            </div>
            <div class="mt-3 mb-3">
                <label for="comment" class="form-label">Comments</label>
                <textarea name="review[comment]" id="comment" class="form-control" cols="30" rows="5" required></textarea>
                <div class="invalid-feedback">Please leave a comment</div>
            </div>
            <button class="btn btn-outline-dark mb-3">Submit</button>
        </form>
         <hr>
         <% } %>
        
        <p><b>All Reviews</b></p>
        <div class="row">
            <% for(review of listing.reviews){%>
                <div class="card col-5 mb-3 ms-3"  >
                    <div class="card-body">
                        <h5 class="card-title">@<%=review.author.username%></h5>
                         <p class="card-text"><%=review.comment%></p>
                          <p class="card-text"><%=review.rating%> star</p>
                    </div>
                    <form method="post" action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE">
                        <button class="btn btn-sm btn-dark mb-3 mt-2">Delete</button>
                    </form>
                </div>
            <%}%>
        </div>
            

    </div>

      <script src="/js/script.js"></script>


